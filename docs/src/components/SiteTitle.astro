<style>
	.site-title {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		white-space: nowrap;
		min-width: 0;
	}

	.mascot {
		height: 28px;
		width: auto;
		flex-shrink: 0;
	}

	.title-text {
		font-family: 'MDUI', sans-serif;
		font-size: 20px;
		font-weight: 500;
		line-height: 28px;
		color: #38362e;
	}

	/* ---- transform context ---- */
	#mm,
	#mm * {
		transform-box: fill-box;
		transform-origin: center;
	}

	/* ---- idle animations ---- */
	#mm {
		animation: mm-bob 3.4s ease-in-out infinite;
	}

	@keyframes mm-bob {
		0%, 100% { transform: rotate(-0.6deg); }
		50%       { transform: rotate(0.6deg);  }
	}

	#mm-eye-left,
	#mm-eye-right {
		animation: mm-blink 4.6s ease-in-out infinite;
	}

	@keyframes mm-blink {
		0%, 92%, 100% { transform: scaleY(1);   }
		95%            { transform: scaleY(.08); }
	}

	#mm-pupil-left,
	#mm-pupil-right {
		animation: mm-glance 5.2s ease-in-out infinite;
	}

	@keyframes mm-glance {
		0%,  20% { transform: translate(0,    0);   }
		30%, 44% { transform: translate(6px, -2px); }
		56%, 72% { transform: translate(-7px, 1px); }
		84%,100% { transform: translate(0,    0);   }
	}

	#mm-brow-left,
	#mm-brow-right {
		animation: mm-browraise 5.2s ease-in-out infinite;
	}

	@keyframes mm-browraise {
		0%,  55%, 100% { transform: translateY(0);    }
		62%, 78%        { transform: translateY(-5px); }
	}

	/* ---- strokes / fills ---- */
	#mm-body-path {
		fill: none;
		stroke: #38362e;
		stroke-width: 14;
		stroke-linejoin: round;
	}

	#mm-eye-left path,
	#mm-eye-right path {
		fill: none;
		stroke: #38362e;
		stroke-width: 10;
	}

	#mm-pupil-left,
	#mm-pupil-right {
		fill: #38362e;
	}

	#mm-brow-left,
	#mm-brow-right {
		fill: none;
		stroke: #38362e;
		stroke-width: 10;
		stroke-linecap: round;
	}

	#mm-mouth {
		fill: none;
		stroke: #38362e;
		stroke-width: 10;
		stroke-linecap: round;
	}
</style>
